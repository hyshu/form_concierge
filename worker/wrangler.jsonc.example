{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "form-concierge-api",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-22",
  "observability": {
    "enabled": true,
    "logs": {
      "head_sampling_rate": 1
    },
    "traces": {
      "enabled": true,
      "head_sampling_rate": 0.01
    }
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "form_concierge",
      // Filled by `form_concierge setup cloudflare`. For local-only wrangler
      // dev, any UUID works after `npm run d1:migrate:local`.
      // Never set "remote": true here — that makes `wrangler dev` hit production.
      "database_id": "00000000-0000-0000-0000-000000000000",
      "migrations_dir": "migrations"
    }
  ],
  "ratelimits": [
    {
      "name": "LOGIN_RATE_LIMITER",
      "namespace_id": "1001",
      "simple": { "limit": 20, "period": 60 }
    },
    {
      "name": "ANON_CREATE_RATE_LIMITER",
      "namespace_id": "1002",
      "simple": { "limit": 30, "period": 60 }
    }
  ],
  // store_id filled by setup cloudflare (or set manually after creating a store).
  "secrets_store_secrets": [
    {
      "binding": "GEMINI_API_KEY",
      "store_id": "replace-secrets-store-id",
      "secret_name": "gemini_api_key"
    },
    {
      "binding": "OPENAI_API_KEY",
      "store_id": "replace-secrets-store-id",
      "secret_name": "openai_api_key"
    },
    {
      "binding": "CLAUDE_API_KEY",
      "store_id": "replace-secrets-store-id",
      "secret_name": "claude_api_key"
    },
    {
      "binding": "CEREBRAS_API_KEY",
      "store_id": "replace-secrets-store-id",
      "secret_name": "cerebras_api_key"
    },
    {
      "binding": "SMTP_PASSWORD",
      "store_id": "replace-secrets-store-id",
      "secret_name": "smtp_password"
    },
    {
      // Public site key still stored in Secrets Store so admin can set both keys together.
      "binding": "TURNSTILE_SITE_KEY",
      "store_id": "replace-secrets-store-id",
      "secret_name": "turnstile_site_key"
    },
    {
      "binding": "TURNSTILE_SECRET_KEY",
      "store_id": "replace-secrets-store-id",
      "secret_name": "turnstile_secret_key"
    }
  ],
  "r2_buckets": [
    {
      // Reserved for future media uploads; not yet referenced by application code.
      "binding": "MEDIA_BUCKET",
      "bucket_name": "form-concierge-media"
    }
  ],
  "vars": {
    "PUBLIC_BASE_URL": "http://localhost:8787",
    "PUBLIC_FORM_ASSET_BASE_URL": "http://localhost:8081",
    // Filled by setup cloudflare
    "CF_ACCOUNT_ID": "replace-account-id",
    "CF_SECRETS_STORE_ID": "replace-secrets-store-id"
    // Optional AI model overrides (defaults live in ai_generation.ts):
    // "AI_GEMINI_MODEL": "gemini-3.5-flash",
    // "AI_OPENAI_MODEL": "gpt-5.5",
    // "AI_CLAUDE_MODEL": "claude-sonnet-4-6",
    // "AI_CEREBRAS_MODEL": "gpt-oss-120b"
  }
}
