{
  "name": "form-concierge-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "node scripts/check-deploy.mjs && wrangler deploy",
    "types:worker": "node scripts/check-worker-types.mjs --write",
    "check:worker-types": "node scripts/check-worker-types.mjs",
    "typecheck": "npm run check:worker-types && tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "typecheck:deployment": "node scripts/check-deployment-types.mjs",
    "test:typecheck": "tsc --noEmit -p tsconfig.test.json",
    "test": "tsx --test \"src/**/*.test.ts\" && tsx --test \"test/**/*.integration.test.ts\"",
    "d1:migrate:local": "wrangler d1 migrations apply form_concierge --local",
    "d1:migrate:remote": "wrangler d1 migrations apply form_concierge --remote"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260620.0",
    "@types/node": "^26.0.0",
    "tsx": "^4.22.4",
    "typescript": "^5.8.3",
    "wrangler": "^4.21.0"
  }
}
