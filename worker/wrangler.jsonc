{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "form-concierge-api",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-22",
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "form_concierge",
      "database_id": "d2fe5861-447d-4a41-841b-6b84996eef70",
      "migrations_dir": "migrations"
    }
  ],
  "vars": {
    "PUBLIC_BASE_URL": "http://localhost:8787",
    "PUBLIC_FORM_ASSET_BASE_URL": "http://localhost:8081"
  }
}
